<Page
    x:Class="ScrcpyGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="SemiBold" />
            <TextBlock Text="Configure scrcpy mirroring properties and application paths" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Scrollable Settings Groups -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Padding="0,0,16,24">
                
                <!-- Group 1: Performance & Quality -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Performance &amp; Resolution" Style="{ThemeResource ListSectionHeaderTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <!-- Card: Max Size -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Maximum Resolution Limit" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Limit both width and height of the video (0 = Native device resolution)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="1920" StepFrequency="120" Value="{x:Bind ViewModel.MaxSize, Mode=TwoWay}" Header="{x:Bind GetMaxSizeHeader(ViewModel.MaxSize), Mode=OneWay}" />
                        </Grid>
                    </Border>

                    <!-- Card: Bitrate -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Video Bitrate" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Higher bitrate offers better quality but demands more USB/Wi-Fi bandwidth" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" SelectedIndex="{x:Bind ViewModel.BitrateIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="2M" />
                                <ComboBoxItem Content="4M" />
                                <ComboBoxItem Content="8M" />
                                <ComboBoxItem Content="16M" />
                                <ComboBoxItem Content="32M" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Card: Max FPS -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Frame Rate Limit" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Limit the maximum rendering FPS (0 = Unlimited)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="120" StepFrequency="15" Value="{x:Bind ViewModel.MaxFps, Mode=TwoWay}" Header="{x:Bind GetMaxFpsHeader(ViewModel.MaxFps), Mode=OneWay}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 2: Android Stay Awake & Audio -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Device Audio &amp; Power Control" Style="{ThemeResource ListSectionHeaderTextBlockStyle}" FontWeight="SemiBold" />

                    <!-- Card: Disable Audio -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Disable Audio Mirroring" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Turn off audio streaming from the Android device to the PC" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.DisableAudio, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Turn Screen Off -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Turn Off Device Screen" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Turn off the physical Android screen during mirroring to save battery" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.TurnScreenOff, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Stay Awake -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Prevent Device Sleep" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Force the device to stay awake while connected" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.StayAwake, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 3: Keyboard/Mouse OTG & Display -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Window &amp; Input Options" Style="{ThemeResource ListSectionHeaderTextBlockStyle}" FontWeight="SemiBold" />

                    <!-- Card: Keep On Top -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Always On Top" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Keep the mirrored screen window on top of other PC windows" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.KeepOnTop, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Fullscreen -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Start in Fullscreen" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Launch the mirroring window in full-screen mode" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.Fullscreen, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: OTG Mode -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="OTG Mode (HID Keyboard/Mouse only)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Simulate USB Keyboard/Mouse input directly without mirroring the video screen" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.OtgMode, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 4: Paths & Custom parameters -->
                <StackPanel Spacing="8">
                    <TextBlock Text="System Paths &amp; CLI Customization" Style="{ThemeResource ListSectionHeaderTextBlockStyle}" FontWeight="SemiBold" />

                    <!-- Card: Custom scrcpy Path Toggle -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Use Custom scrcpy Path" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Specify a local custom directory for scrcpy/ADB binaries instead of using auto-downloaded ones" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.UseCustomScrcpyPath, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Custom Path Textbox -->
                    <Border CornerRadius="8" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            Padding="16" 
                            Visibility="{x:Bind BoolToVisibility(ViewModel.UseCustomScrcpyPath), Mode=OneWay}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Header="Custom scrcpy Folder Path" Text="{x:Bind ViewModel.CustomScrcpyPath, Mode=TwoWay}" PlaceholderText="C:\path\to\scrcpy-win64" HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseButton_Click">
                                <SymbolIcon Symbol="Folder" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Card: Custom CLI Args -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <TextBox Header="Additional Command-Line Arguments" Text="{x:Bind ViewModel.CustomArguments, Mode=TwoWay}" PlaceholderText="e.g. --turn-screen-off --no-audio" HorizontalAlignment="Stretch" />
                    </Border>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
