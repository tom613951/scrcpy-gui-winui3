<Page
    x:Class="ScrcpyGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="系统设置" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="SemiBold" />
            <TextBlock Text="配置 scrcpy 投屏属性与应用程序运行路径" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Scrollable Settings Groups -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Padding="0,0,16,24">
                
                <!-- Group 0: Session Mode -->
                <StackPanel Spacing="8">
                    <TextBlock Text="投屏模式" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="运行模式" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="选择投屏内容（屏幕、相机、桌面）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" SelectedValue="{x:Bind ViewModel.SessionMode, Mode=TwoWay}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="屏幕镜像 (Mirror)" Tag="mirror" />
                                <ComboBoxItem Content="相机投屏 (Camera)" Tag="camera" />
                                <ComboBoxItem Content="虚拟桌面 (Desktop)" Tag="desktop" />
                            </ComboBox>
                        </Grid>
                    </Border>
                    
                    <!-- Camera Mode Specific Settings -->
                    <StackPanel Spacing="8" Visibility="{x:Bind BoolToVisibility(ViewModel.IsCameraMode), Mode=OneWay}">
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="相机模式专属配置" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                
                                <TextBox Header="Camera ID" Text="{x:Bind ViewModel.CameraId, Mode=TwoWay}" PlaceholderText="留空则自动选择" />
                                <TextBox Header="视频编码器 (Codec)" Text="{x:Bind ViewModel.Codec, Mode=TwoWay}" PlaceholderText="例如 h264, h265, av1" />
                                <TextBox Header="相机画面比例 (Aspect Ratio)" Text="{x:Bind ViewModel.CameraAr, Mode=TwoWay}" PlaceholderText="例如 16:9, 4:3" />
                                <ToggleSwitch Header="开启闪光灯 (Torch)" IsOn="{x:Bind ViewModel.CameraTorch, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Desktop Mode Specific Settings -->
                    <StackPanel Spacing="8" Visibility="{x:Bind BoolToVisibility(ViewModel.IsDesktopMode), Mode=OneWay}">
                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="虚拟桌面专属配置" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                
                                <NumberBox Header="桌面宽度 (px)" Value="{x:Bind ViewModel.VdWidth, Mode=TwoWay}" SpinButtonPlacementMode="Inline" />
                                <NumberBox Header="桌面高度 (px)" Value="{x:Bind ViewModel.VdHeight, Mode=TwoWay}" SpinButtonPlacementMode="Inline" />
                                <NumberBox Header="DPI (缩放)" Value="{x:Bind ViewModel.VdDpi, Mode=TwoWay}" SpinButtonPlacementMode="Inline" />
                                <ToggleSwitch Header="动态显示调整 (Flex Display)" IsOn="{x:Bind ViewModel.FlexDisplay, Mode=TwoWay}" />
                                <TextBox Header="背景颜色 (Hex)" Text="{x:Bind ViewModel.BackgroundColor, Mode=TwoWay}" PlaceholderText="#222222" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Group 1: Performance & Quality -->
                <StackPanel Spacing="8">
                    <TextBlock Text="性能与分辨率" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <!-- Card: Max Size -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="最大分辨率限制" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="限制投屏视频画面的最大宽度和高度（0 = 使用安卓设备原生分辨率）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="1920" StepFrequency="120" Value="{x:Bind ViewModel.MaxSize, Mode=TwoWay}" Header="{x:Bind GetMaxSizeHeader(ViewModel.MaxSize), Mode=OneWay}" />
                        </Grid>
                    </Border>

                    <!-- Card: Bitrate -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="视频码率 (Bitrate)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="较高的码率可以提供更清晰的画面，但对 USB 传输或 Wi-Fi 带宽要求更高" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" SelectedIndex="{x:Bind ViewModel.BitrateIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="2M" />
                                <ComboBoxItem Content="4M" />
                                <ComboBoxItem Content="8M" />
                                <ComboBoxItem Content="16M" />
                                <ComboBoxItem Content="32M" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Card: Max FPS -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="帧率限制 (FPS)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="限制投屏画面的最高帧率（0 = 无限制）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="120" StepFrequency="15" Value="{x:Bind ViewModel.MaxFps, Mode=TwoWay}" Header="{x:Bind GetMaxFpsHeader(ViewModel.MaxFps), Mode=OneWay}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 2: Android Stay Awake & Audio -->
                <StackPanel Spacing="8">
                    <TextBlock Text="设备音频与电源管理" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />

                    <!-- Card: Disable Audio -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="禁用音频传输" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="关闭从安卓设备到电脑的音频同步传输（投屏时保持电脑静音）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.DisableAudio, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Turn Screen Off -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="自动关闭设备屏幕" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="投屏启动后，自动关闭手机/平板的物理屏幕，以节省电量并防止烧屏" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.TurnScreenOff, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Stay Awake -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="防止设备自动休眠" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="投屏时强制保持安卓设备为唤醒状态" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.StayAwake, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 3: Keyboard/Mouse OTG & Display -->
                <StackPanel Spacing="8">
                    <TextBlock Text="窗口与输入控制" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />

                    <!-- Card: HID Keyboard -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="UHID 物理键盘模拟 (HID Keyboard)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="使用 UHID 协议直连设备，跳过安卓输入法，支持系统级快捷键（需连接 USB）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.HidKeyboard, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: HID Mouse -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="UHID 物理鼠标模拟 (HID Mouse)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="使用 UHID 协议直连设备，捕获鼠标原始移动事件，适合打游戏（需连接 USB）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.HidMouse, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Keep On Top -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="投屏窗口置顶" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="保持投屏画面窗口始终置于电脑其他窗口最前端" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.KeepOnTop, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Fullscreen -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="以全屏模式启动" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="投屏窗口启动时直接进入全屏状态" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.Fullscreen, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: OTG Mode -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="OTG 键鼠模式 (仅 HID)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="仅将电脑键鼠输入模拟为物理 USB 键鼠直连设备，不显示投屏画面（仅限 USB 连接）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.OtgMode, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 4: Paths & Custom parameters -->
                <StackPanel Spacing="8">
                    <TextBlock Text="系统路径与命令行自定义" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />

                    <!-- Card: Custom scrcpy Path Toggle -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="使用自定义 scrcpy 路径" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="指定本地已有的 scrcpy 文件夹，而不使用本软件自动下载托管的版本" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.UseCustomScrcpyPath, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Border>

                    <!-- Card: Custom Path Textbox -->
                    <Border CornerRadius="8" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            Padding="16" 
                            Visibility="{x:Bind BoolToVisibility(ViewModel.UseCustomScrcpyPath), Mode=OneWay}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Header="自定义 scrcpy 目录路径" Text="{x:Bind ViewModel.CustomScrcpyPath, Mode=TwoWay}" PlaceholderText="例如 C:\tools\scrcpy-win64" HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Click="BrowseButton_Click">
                                <SymbolIcon Symbol="Folder" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Card: Custom CLI Args -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                        <TextBox Header="附加命令行参数" Text="{x:Bind ViewModel.CustomArguments, Mode=TwoWay}" PlaceholderText="例如 --turn-screen-off --no-audio" HorizontalAlignment="Stretch" />
                    </Border>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
