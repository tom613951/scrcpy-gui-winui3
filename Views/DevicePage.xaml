<Page
    x:Class="ScrcpyGui.Views.DevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ScrcpyGui.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="12" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- Page Header & Actions -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Devices" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="SemiBold" />
                <TextBlock Text="Select a connected Android device to start screen mirroring" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <!-- Check if binaries are missing -->
                <Border Background="#FFF4CE" BorderThickness="1" BorderBrush="#F3CA7E" CornerRadius="4" Padding="12,6" Margin="0,0,12,0" 
                        Visibility="{x:Bind BoolToVisibility(ViewModel.IsBinariesMissing), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Important" Foreground="#9F6A00" />
                        <TextBlock Text="scrcpy binaries are missing! Please go to Package Manager." Foreground="#9F6A00" VerticalAlignment="Center" FontWeight="Medium" />
                    </StackPanel>
                </Border>
                
                <Button Command="{x:Bind ViewModel.RefreshDevicesCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="Refresh Devices" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Area: Left side Device List / Right side Wireless panel -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Device list column (UniGetUI Cards style) -->
            <Grid>
                <!-- Empty State Placeholder -->
                <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="32" VerticalAlignment="Top"
                        Visibility="{x:Bind IsListEmpty(ViewModel.Devices.Count), Mode=OneWay}">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <SymbolIcon Symbol="CellPhone" Height="48" Width="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="No connected devices found" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" FontWeight="Medium" />
                        <TextBlock Text="Connect your Android device via USB (with Developer options &amp; USB Debugging enabled) or use the Wireless connect panel on the right." Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="400" />
                    </StackPanel>
                </Border>

                <!-- Connected Devices Card List -->
                <ListView ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}" 
                          SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                          SelectionMode="Single"
                          Visibility="{x:Bind IsListNotEmpty(ViewModel.Devices.Count), Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AdbDevice">
                            <!-- Card Container -->
                            <Border Margin="0,4,0,4" 
                                    HorizontalAlignment="Stretch"
                                    CornerRadius="6" 
                                    BorderThickness="1" 
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                    Padding="16,12">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Device Icon -->
                                    <FontIcon Glyph="&#xE8EA;" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />

                                    <!-- Device info -->
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Model}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <!-- Connection Type icon -->
                                            <FontIcon Glyph="{x:Bind ConnectionIcon}" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind Serial}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Connection status badge and quick mirror button -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <Border CornerRadius="4" Padding="8,4" Background="{x:Bind StatusBrush}">
                                            <TextBlock Text="{x:Bind Status}" Foreground="White" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Wireless Connect / Pairing Panel (UniGetUI Right Panel Style) -->
            <StackPanel Grid.Column="1" Spacing="16">
                <!-- Connect Card -->
                <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Wi-Fi ADB Connection" Style="{ThemeResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="Connect to Android device wirelessly (must be on the same local network)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        
                        <TextBox Header="IP Address" Text="{x:Bind ViewModel.WirelessIpAddress, Mode=TwoWay}" PlaceholderText="192.168.1.100" />
                        <NumberBox Header="ADB Port" Value="{x:Bind ViewModel.WirelessPort, Mode=TwoWay}" PlaceholderText="5555" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact" />
                        
                        <Button Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.WirelessConnectCommand}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Remote" />
                                <TextBlock Text="Connect" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Pairing Card -->
                <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Android 11+ Pairing" Style="{ThemeResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="Pair device using Pairing Port and Pairing Code from developer options" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        
                        <TextBox Header="Pairing Code" Text="{x:Bind ViewModel.PairingCode, Mode=TwoWay}" PlaceholderText="123456" />
                        
                        <Button Command="{x:Bind ViewModel.WirelessPairCommand}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Permissions" />
                                <TextBlock Text="Pair Device" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Status message output -->
                <TextBlock Text="{x:Bind ViewModel.WirelessStatusMessage, Mode=OneWay}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ADB & Scrcpy Terminal log output panel (Bottom Card) -->
        <Border Grid.Row="2" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="scrcpy Output Console" Style="{ThemeResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.StartMirroringCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Play" />
                                <TextBlock Text="Start Mirroring" />
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ClearLogCommand}">
                            <SymbolIcon Symbol="Clear" />
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" Background="Black" CornerRadius="4" Padding="12">
                    <TextBlock Text="{x:Bind ViewModel.LogOutput, Mode=OneWay}" 
                               FontFamily="Consolas" 
                               FontSize="12" 
                               Foreground="LightGray" 
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
