<Page
    x:Class="ScrcpyGui.Views.DevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ScrcpyGui.Models"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop">

    <Grid Margin="12" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header & Actions -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="设备列表" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="SemiBold" />
                <TextBlock Text="选择已连接的安卓设备以启动屏幕投屏" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <!-- Check if binaries are missing -->
                <Border Background="#FFF4CE" BorderThickness="1" BorderBrush="#F3CA7E" CornerRadius="4" Padding="12,6" Margin="0,0,12,0" 
                        Visibility="{x:Bind BoolToVisibility(ViewModel.IsBinariesMissing), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Important" Foreground="#9F6A00" />
                        <TextBlock Text="未找到 scrcpy 核心文件！请前往“系统设置”配置 scrcpy 目录路径。" Foreground="#9F6A00" VerticalAlignment="Center" FontWeight="Medium" />
                    </StackPanel>
                </Border>
                <Button Command="{x:Bind ViewModel.KillAdbCommand}" ToolTipService.ToolTip="强制终止并重启 ADB 进程">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Cancel" />
                        <TextBlock Text="终止 ADB 服务" />
                    </StackPanel>
                </Button>
                
                <Button Command="{x:Bind ViewModel.RefreshDevicesCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="刷新设备列表" />
                    </StackPanel>
                </Button>
                
                <Button Click="SettingsButton_Click" ToolTipService.ToolTip="系统设置与安装管理器">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Setting" />
                        <TextBlock Text="系统设置" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Area: Left side (List + Wireless) / Right side (Console) -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Devices and Wireless -->
            <Grid Grid.Column="0" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Device list column (UniGetUI Cards style) -->
                <Grid Grid.Row="0">
                    <!-- Empty State Placeholder -->
                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="32" VerticalAlignment="Top"
                            Visibility="{x:Bind IsListEmpty(ViewModel.Devices.Count), Mode=OneWay}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <SymbolIcon Symbol="CellPhone" Height="48" Width="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="未找到已连接的设备" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" FontWeight="Medium" />
                            <TextBlock Text="请通过 USB 数据线连接您的安卓设备（需开启“开发者选项”与“USB 调试”），或使用下方的无线连接面板进行连接。" Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="400" />
                        </StackPanel>
                    </Border>

                    <!-- Connected Devices Card List -->
                    <ListView ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}" 
                              SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                              SelectionMode="Single"
                              Visibility="{x:Bind IsListNotEmpty(ViewModel.Devices.Count), Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AdbDevice">
                                <!-- Card Container -->
                                <Border Margin="0,4,0,4" 
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="6" 
                                        BorderThickness="1" 
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                        Padding="16,12">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Device Icon -->
                                        <FontIcon Glyph="&#xE8EA;" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />

                                        <!-- Device info -->
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Model}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <!-- Connection Type icon -->
                                                <FontIcon Glyph="{x:Bind ConnectionIcon}" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Bind Serial}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Connection status badge and quick mirror button -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                            <Border CornerRadius="4" Padding="8,4" Background="{x:Bind StatusBrush}">
                                                <TextBlock Text="{x:Bind StatusDisplayName}" Foreground="White" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>

                <!-- Connect Card -->
                <Border Grid.Row="1" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel>
                            <TextBlock Text="无线 ADB 连接" Style="{ThemeResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" />
                            <TextBlock Text="无线连接安卓设备（设备与电脑必须处于同一局域网中）" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Header="IP 地址" Text="{x:Bind ViewModel.WirelessIpAddress, Mode=TwoWay}" PlaceholderText="例如 192.168.1.100" />
                            <NumberBox Grid.Column="1" Header="ADB 端口" Value="{x:Bind ViewModel.WirelessPort, Mode=TwoWay}" PlaceholderText="默认 5555" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact" />
                            <Button Grid.Column="2" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.WirelessConnectCommand}" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Remote" />
                                    <TextBlock Text="连接" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Pairing Card -->
                <Border Grid.Row="2" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel>
                            <TextBlock Text="Android 11+ 无线配对" Style="{ThemeResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" />
                            <TextBlock Text="使用开发者选项中的配对端口和配对码与设备进行配对" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Header="配对码" Text="{x:Bind ViewModel.PairingCode, Mode=TwoWay}" PlaceholderText="请输入配对码" />
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.WirelessPairCommand}" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Permissions" />
                                    <TextBlock Text="配对设备" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.WirelessStatusMessage, Mode=OneWay}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right Column: ADB & Scrcpy Terminal log output panel -->
            <Border Grid.Column="1" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="scrcpy 进程控制台日志" Style="{ThemeResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.StartMirroringCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="启动投屏" />
                                </StackPanel>
                            </Button>
                            <Button Command="{x:Bind ViewModel.ClearLogCommand}" ToolTipService.ToolTip="清空控制台">
                                <SymbolIcon Symbol="Clear" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Background="Black" CornerRadius="4" Padding="12">
                        <TextBlock Text="{x:Bind ViewModel.LogOutput, Mode=OneWay}" 
                                   FontFamily="Consolas" 
                                   FontSize="12" 
                                   Foreground="LightGray" 
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
